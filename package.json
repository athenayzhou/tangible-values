    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"*.{js,html}\" \"vite.config.js\" \"vitest.config.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"*.{js,html}\" \"vite.config.js\" \"vitest.config.js\"",
    "test": "vitest run",
    "test:watch": "vitest"
